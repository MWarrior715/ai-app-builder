# Motor de IA Local/Cloud (OpenAI-compatible API).
# Por defecto apunta a un motor local; cambia BASE_URL/API_KEY para tu motor.

OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=local-dev-key
LLM_MODEL=qwen2.5:7b-instruct

# Directorio de salida para proyectos generados.
OUTPUT_DIR=./outputs